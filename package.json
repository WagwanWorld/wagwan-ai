{
  "name": "wagwan-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "npm run check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint scripts tests eslint.config.js vitest.config.ts",
    "lint:repo": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "deadcode:audit": "node scripts/dead-code-audit.mjs",
    "validate": "npm run format:check && npm run lint && npm run deadcode:audit && npm run typecheck && npm run test && npm run build",
    "prepare": "husky",
    "orio": "bash scripts/orio-up.sh",
    "supabase:migrate": "node --env-file=.env scripts/apply-supabase-migrations.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@fontsource/bodoni-moda": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@google-cloud/storage": "^7.19.0",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@lucide/svelte": "^1.7.0",
    "@supabase/supabase-js": "^2.101.1",
    "jsonwebtoken": "^9.0.3",
    "phosphor-svelte": "^3.1.0",
    "redis": "^4.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.7.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pg": "^8.13.1",
    "postcss": "^8.4.49",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.4.16",
    "tslib": "^2.8.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^5.4.11",
    "vitest": "^3.2.4"
  },
  "type": "module",
  "lint-staged": {
    "*.{js,ts,svelte,json,md,css}": [
      "prettier --write"
    ]
  }
}
