# ── Anthropic (required) ─────────────────────────────────
# Get from: https://console.anthropic.com/
# Used for chat, shop, home cards, and POST /api/refresh-signals identity inference (behaviour graph on Earn).
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override chat model if the default snapshot ID is unavailable on your account.
# CHAT_ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Chat LLM provider (default: Anthropic) ────────────────────────────────
# CHAT_LLM_PROVIDER=anthropic   # anthropic | ollama | openai_compatible
# Backup: keep Anthropic primary but retry chat on local Ollama if the API fails (install: brew install ollama; run: ollama serve; model: ollama pull llama3.2:1b — default is this light ~1.3GB model; use CHAT_OLLAMA_MODEL=llama3.2 for heavier quality).
# CHAT_OLLAMA_FALLBACK=true
# For Ollama (local): set CHAT_LLM_PROVIDER=ollama and run ollama serve.
# CHAT_OLLAMA_BASE_URL=http://127.0.0.1:11434   # overrides OLLAMA_BASE_URL for chat only
# CHAT_OLLAMA_MODEL=llama3.2:1b
# For OpenAI-compatible APIs (LM Studio, vLLM, etc.):
# CHAT_LLM_PROVIDER=openai_compatible
# CHAT_OPENAI_COMPATIBLE_BASE_URL=http://127.0.0.1:1234/v1
# CHAT_OPENAI_COMPATIBLE_API_KEY=sk-...
# CHAT_OPENAI_COMPATIBLE_MODEL=meta-llama-3.1-8b-instruct

# Optional: max characters for Tier A signal pack in /api/chat (default 4000, min 800).
# CHAT_SIGNAL_PACK_MAX_CHARS=4000

# ── Twin thread summarization (optional — local LLM, no token cost) ────────
# Rolling memory for /api/chat/summarize. With Ollama running locally (ollama.com),
# set OLLAMA_BASE_URL so summaries can skip Anthropic. Serverless deploys cannot reach
# localhost unless Ollama is on a reachable host.
# THREAD_SUMMARY_PROVIDER=auto   # auto | ollama | anthropic (default auto)
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2:1b

# ── Brave Search API (web results — chat, explore, recommendations) ─────────
# https://api-dashboard.search.brave.com/ → API Keys → Web Search API
# Paste the full subscription token (often starts with BSA). No quotes. If you see
# SUBSCRIPTION_TOKEN_INVALID in server logs, regenerate the key or confirm your plan includes Web Search.
BRAVE_API_KEY=BSA...

# Optional: Brave in-memory search cache TTL (ms). Default 720000 (12 min). Min 60000, max 86400000.
# BRAVE_CACHE_TTL_MS=1800000

# ── Instagram Basic Display API (required for identity) ───
# 1. Create a Facebook Developer App at https://developers.facebook.com/
# 2. Add "Instagram Basic Display" product
# 3. Add your app's redirect URI below to the allowed list
# 4. Copy App ID and App Secret here
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# ── App config ────────────────────────────────────────────
# Base URL for the app. OAuth redirect URIs are built as {PUBLIC_BASE_URL}/auth/<provider>/callback;
# register the exact same URL in each provider (scheme, host, path; no trailing slash on the base).
# Change to your deployed URL in production; rebuild after changing (public env is baked in at build).
PUBLIC_BASE_URL=http://localhost:5173

# Optional: if identity graph last activity is older than this many days, the app may POST
# /api/refresh-signals once (debounced) after loading the profile. Set to 0 to disable. Default 7.
# GRAPH_MAX_AGE_DAYS=7

# Secret for signing session cookies (any random string, 32+ chars)
COOKIE_SECRET=change-me-to-a-long-random-string-in-production

# ── LinkedIn (optional — career signals + jobs section) ───
# 1. Create app at https://developer.linkedin.com/
# 2. Products → Add "Sign In with LinkedIn using OpenID Connect"
# 3. Auth → OAuth 2.0 settings → add redirect URI: {PUBLIC_BASE_URL}/auth/linkedin/callback
#    Example with PUBLIC_BASE_URL above: http://localhost:5173/auth/linkedin/callback
# 4. Copy Client ID and Primary Client Secret here
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Apple Music (optional — MusicKit JS, requires Apple Developer account) ───
# 1. Sign in at https://developer.apple.com/account/
# 2. Certificates, Identifiers & Profiles → Keys → create a new key
#    - Check "Media Services (MusicKit)" capability
#    - Download the .p8 file (you can only download it once)
# 3. Note your Team ID (top-right of developer.apple.com account page)
# 4. Note the Key ID shown after creating the key
# 5. Paste the entire .p8 file as one line — replace real newlines with \n (value is long, ~250+ chars).
#    Example: -----BEGIN PRIVATE KEY-----\nMIGH...\n-----END PRIVATE KEY-----
# Deployed apps: set these in the host’s environment and redeploy/restart — they are read at runtime.
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
# Optional: two-letter storefront for catalog search (default us)
# APPLE_MUSIC_STOREFRONT=us

# ── Supabase (profiles, identity graph, multi-agent chats) ───────────
# 1. Create a project at https://supabase.com/dashboard
# 2. Settings → API → Project URL and service_role key (server-only; never expose to the browser)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# 3. Apply schema: paste supabase/migration.sql through 007_wagwan_user_link.sql in order
#    in the SQL Editor — or set the Postgres URI below and run: npm run supabase:migrate
# SUPABASE_DB_URL=postgresql://postgres.[PROJECT_REF]:[DB_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# ── Wagwan platform link (/api/wagwan/*) ────────────────────────────────
# HS256 secret must match wagwan backend PUBLIC_KEY (same string). Used to verify
# Bearer tokens on POST /api/wagwan/link, GET /api/wagwan/me, GET /api/wagwan/identity.
# WAGWAN_JWT_SECRET=

# gRPC endpoint for Wagwan auth service (OTP login). Default 127.0.0.1:50051.
# Used by POST /api/wagwan/auth/send-otp and /api/wagwan/auth/verify-otp.
WAGWAN_GRPC_URL=127.0.0.1:50051

# Onboarding: show “Continue with Google or Instagram instead” on the phone step (e.g. while OTP is not ready).
# Set true locally or on staging; set false and rebuild when phone login is reliable. (Always shown in `vite dev`.)
PUBLIC_ENABLE_SKIP_PHONE_ONBOARDING=false

# ── Brand portal (/brands + /api/brand/*) ─────────────────
# Operator flow: /brands → Explore audiences (/brands/portal) works without signing in (prompt + ranked search).
# Sign in at /brands/login only to launch a campaign (channels + create) or use X-Brand-Key on protected APIs.
#
# Public discovery endpoints (no session): POST /api/brand/parse-prompt, POST /api/brand/search-audience.
# Anyone who can reach your origin can call them—use network controls or rate limits in production if needed.
# Campaign creation stays behind assertBrandAccess: POST /api/brand/create-campaign.
#
# Required in .env (copy this file to .env and fill values; restart the dev server):
#   COOKIE_SECRET        — signs the httpOnly brand session cookie (src/lib/server/marketplace/brandSession.ts)
#   BRAND_PORTAL_SECRET — password for /brands/login; same value can be sent as X-Brand-Key on API calls
#                         (src/routes/api/brands/login/+server.ts, src/lib/server/marketplace/brandAuth.ts)
#
# Log out: POST /api/brands/logout (or clear wagwan_brand_session cookie).
#
# Optional: allow API access without logging in (google_sub allowlist for scripts / founders).
# BRAND_ALLOWLIST_GOOGLE_SUBS=sub1,sub2
# Optional: tie listing order slightly to identity graph strength (match_score + 0.05 * graph_strength).
# BRAND_RANK_STRENGTH_BOOST=true
#
BRAND_PORTAL_SECRET=
